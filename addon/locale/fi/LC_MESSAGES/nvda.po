#. Translators: The label for the menu item to open Application specific speech dictionary dialog.
#: addon\globalPlugins\applicationDictionary\old__init__.py:118
#: addon\globalPlugins\applicationDictionary\__init__.py:119
msgid "&Application Dictionary..."
msgstr "&Sovellus..."

#: addon\globalPlugins\applicationDictionary\old__init__.py:118
#: addon\globalPlugins\applicationDictionary\__init__.py:119
msgid ""
"A dialog where you can set application-specific dictionary by adding "
"dictionary entries to the list"
msgstr ""
"Valintaikkuna, jossa voit määrittää sovelluskohtaisen sanaston lisäämällä "
"luetteloon sanastomerkintöjä"

#. Translators: Message to be announced during Keyboard Help
#: addon\globalPlugins\applicationDictionary\old__init__.py:131
#: addon\globalPlugins\applicationDictionary\__init__.py:133
msgid "Shows the application-specific dictionary dialog"
msgstr "Näyttää sovelluskohtaisen sanastovalintaikkunan"

#: addon\globalPlugins\applicationDictionary\old__init__.py:143
#: addon\globalPlugins\applicationDictionary\__init__.py:145
msgid "Dictionary for {arg0}"
msgstr "Sanasto sovellukselle {arg0}"

#. Translators: the label of a message box dialog.
#: addon\installTasks.py:19
msgid ""
"You have installed an incompatible version of the add-on. Do you want to "
"uninstall the incompatible version?"
msgstr ""
"Sinulla on asennettuna tämän lisäosan yhteensopimaton versio. Haluatko "
"poistaa sen?"

#. Translators: the title of a message box dialog.
#: addon\installTasks.py:21
msgid "Uninstall incompatible add-on"
msgstr "Poista yhteensopimaton versio"

#. Add-on summary/title, usually the user visible name of the add-on
#. Translators: Summary/title for this add-on
#. to be shown on installation and add-on information found in add-on store
#: buildVars.py:21
msgid "Application dictionary"
msgstr "Sovellussanasto"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-on store
#: buildVars.py:24
msgid ""
"Allows creation of application-specific dictionaries. Use the command "
"\"NVDA+Control+Shift+d\" to access the dictionary for the current "
"application."
msgstr ""
"Mahdollistaa sovelluskohtaisten sanastojen luomisen. Avaa nykyisen "
"sovelluksen sanasto painamalla NVDA+Ctrl+Vaihto+D."

#. Brief changelog for this version
#. Translators: what's new content for the add-on version to be shown in the add-on store
#: buildVars.py:29
msgid ""
"Set compatibility with NVDA 2026.1\n"
"Change code to replace the deprecation of speechDictHandler.dictionaries."
msgstr ""
"Lisätty NVDA 2026.1 -yhteensopivuus\n"
"Koodia päivitetty korvaamaan käytöstä poistuva "
"speechDictHandler.dictionaries-attribuutti."
